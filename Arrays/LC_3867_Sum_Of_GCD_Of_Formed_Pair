class Solution {
public:
    long long gcdSum(vector<int>& nums) {
        int n=nums.size();
        vector<int>v;
        int max1=INT_MIN;
        for(int i=0;i<n;i++){
            max1=max(nums[i],max1);
            v.push_back(gcd(max1,nums[i]));
        }
        sort(v.begin(),v.end());
        int s=0;
        int end=v.size()-1;
        long sum=0;
        while(s<end){
            sum+=gcd(v[s],v[end]);
            s++;
            end--;
        }
        return sum;
    }
};
